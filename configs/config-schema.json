{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Config",
  "$defs": {
    "AuditConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fallback_dir": {
          "type": "string"
        },
        "retention_days": {
          "type": "integer"
        },
        "redaction_level": {
          "type": "string"
        },
        "otlp": {
          "$ref": "#/$defs/AuditOTLPConfig"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "fallback_dir",
        "retention_days",
        "redaction_level",
        "otlp"
      ]
    },
    "AuditOTLPConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "endpoint": {
          "type": "string"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "endpoint",
        "headers"
      ]
    },
    "CapabilitiesConfig": {
      "properties": {
        "fs_read": {
          "type": "boolean",
          "description": "文件系统读权限"
        },
        "fs_write": {
          "type": "boolean",
          "description": "文件系统写权限"
        },
        "terminal": {
          "type": "boolean",
          "description": "终端执行权限"
        }
      },
      "type": "object",
      "required": [
        "fs_read",
        "fs_write",
        "terminal"
      ]
    },
    "Config": {
      "properties": {
        "run": {
          "$ref": "#/$defs/RunConfig"
        },
        "scheduler": {
          "$ref": "#/$defs/SchedulerConfig"
        },
        "server": {
          "$ref": "#/$defs/ServerConfig"
        },
        "github": {
          "$ref": "#/$defs/GitHubConfig"
        },
        "store": {
          "$ref": "#/$defs/StoreConfig"
        },
        "context": {
          "$ref": "#/$defs/ContextConfig"
        },
        "log": {
          "$ref": "#/$defs/LogConfig"
        },
        "audit": {
          "$ref": "#/$defs/AuditConfig"
        },
        "llm_filter": {
          "$ref": "#/$defs/LLMFilterConfig"
        },
        "runtime": {
          "$ref": "#/$defs/RuntimeConfig"
        }
      },
      "type": "object",
      "required": [
        "run",
        "scheduler",
        "server",
        "github",
        "store",
        "context",
        "log",
        "audit",
        "llm_filter",
        "runtime"
      ]
    },
    "ContextConfig": {
      "properties": {
        "provider": {
          "type": "string",
          "description": "上下文提供者（context-sqlite / mock / 空=禁用）"
        },
        "path": {
          "type": "string",
          "description": "SQLite 文件路径"
        }
      },
      "type": "object",
      "required": [
        "provider",
        "path"
      ]
    },
    "GitHubConfig": {
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "是否启用 GitHub 集成"
        },
        "token": {
          "type": "string",
          "description": "GitHub PAT（或通过 secrets.yaml）"
        },
        "app_id": {
          "type": "integer",
          "description": "GitHub App ID"
        },
        "private_key_path": {
          "type": "string",
          "description": "GitHub App 私钥路径"
        },
        "installation_id": {
          "type": "integer",
          "description": "GitHub App 安装 ID"
        },
        "owner": {
          "type": "string",
          "description": "仓库 owner"
        },
        "repo": {
          "type": "string",
          "description": "仓库名"
        },
        "webhook_secret": {
          "type": "string",
          "description": "Webhook 签名密钥"
        },
        "webhook_enabled": {
          "type": "boolean",
          "description": "是否接收 Webhook"
        },
        "pr_enabled": {
          "type": "boolean",
          "description": "是否启用 PR 管理"
        },
        "label_mapping": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "authorized_usernames": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "auto_trigger": {
          "type": "boolean",
          "description": "Issue 创建时自动触发 run"
        },
        "allow_pat_fallback": {
          "type": "boolean",
          "description": "App 认证失败时回退到 PAT"
        },
        "pr": {
          "$ref": "#/$defs/GitHubPRConfig",
          "description": "PR 自动化设置"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "token",
        "app_id",
        "private_key_path",
        "installation_id",
        "owner",
        "repo",
        "webhook_secret",
        "webhook_enabled",
        "pr_enabled",
        "label_mapping",
        "authorized_usernames",
        "auto_trigger",
        "allow_pat_fallback",
        "pr"
      ]
    },
    "GitHubPRConfig": {
      "properties": {
        "auto_create": {
          "type": "boolean",
          "description": "自动创建 PR"
        },
        "draft": {
          "type": "boolean",
          "description": "创建为草稿 PR"
        },
        "auto_merge": {
          "type": "boolean",
          "description": "自动合并"
        },
        "reviewers": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "指定 reviewer"
        },
        "labels": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "PR 标签"
        },
        "branch_prefix": {
          "type": "string",
          "description": "分支名前缀"
        }
      },
      "type": "object",
      "required": [
        "auto_create",
        "draft",
        "auto_merge",
        "reviewers",
        "labels",
        "branch_prefix"
      ]
    },
    "LLMFilterConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "provider",
        "model"
      ]
    },
    "LogConfig": {
      "properties": {
        "level": {
          "type": "string",
          "description": "日志级别（debug / info / warn / error）"
        },
        "file": {
          "type": "string",
          "description": "日志文件路径"
        },
        "max_size_mb": {
          "type": "integer",
          "description": "单个日志文件最大 MB"
        },
        "max_age_days": {
          "type": "integer",
          "description": "日志保留天数"
        }
      },
      "type": "object",
      "required": [
        "level",
        "file",
        "max_size_mb",
        "max_age_days"
      ]
    },
    "MCPConfig": {
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "是否启用 MCP 工具注入"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "注入的 MCP 工具名列表"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "tools"
      ]
    },
    "RunConfig": {
      "properties": {
        "default_template": {
          "type": "string",
          "description": "默认 run 模板（standard / fast_release 等）"
        },
        "global_timeout": {
          "type": "string",
          "description": "单次 run 全局超时",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "auto_infer_template": {
          "type": "boolean",
          "description": "是否自动推断模板"
        },
        "max_total_retries": {
          "type": "integer",
          "description": "最大重试次数"
        }
      },
      "type": "object",
      "required": [
        "default_template",
        "global_timeout",
        "auto_infer_template",
        "max_total_retries"
      ]
    },
    "RuntimeAgentsConfig": {
      "properties": {
        "drivers": {
          "items": {
            "$ref": "#/$defs/RuntimeDriverConfig"
          },
          "type": "array"
        },
        "profiles": {
          "items": {
            "$ref": "#/$defs/RuntimeProfileConfig"
          },
          "type": "array"
        }
      },
      "type": "object",
      "required": [
        "drivers",
        "profiles"
      ]
    },
    "RuntimeCollectorConfig": {
      "properties": {
        "max_retries": {
          "type": "integer"
        }
      },
      "type": "object",
      "required": [
        "max_retries"
      ]
    },
    "RuntimeConfig": {
      "properties": {
        "mock_executor": {
          "type": "boolean",
          "description": "是否使用本地 stub 执行器"
        },
        "collector": {
          "$ref": "#/$defs/RuntimeCollectorConfig",
          "description": "运行时元数据采集配置"
        },
        "llm": {
          "$ref": "#/$defs/RuntimeLLMConfig",
          "description": "LLM API provider 配置"
        },
        "sandbox": {
          "$ref": "#/$defs/RuntimeSandboxConfig",
          "description": "运行时沙箱配置"
        },
        "agents": {
          "$ref": "#/$defs/RuntimeAgentsConfig",
          "description": "运行时 driver 和 profile 配置"
        },
        "mcp": {
          "$ref": "#/$defs/RuntimeMCPConfig",
          "description": "运行时 MCP server 与绑定配置"
        },
        "prompts": {
          "$ref": "#/$defs/RuntimePromptsConfig",
          "description": "运行时提示词模板"
        },
        "session_manager": {
          "$ref": "#/$defs/RuntimeSessionManagerConfig"
        },
        "execution_probe": {
          "$ref": "#/$defs/RuntimeExecutionProbeConfig"
        },
        "cron": {
          "$ref": "#/$defs/RuntimeCronConfig"
        },
        "inspection": {
          "$ref": "#/$defs/RuntimeInspectionConfig"
        }
      },
      "type": "object",
      "required": [
        "mock_executor",
        "collector",
        "llm",
        "sandbox",
        "agents",
        "mcp",
        "prompts",
        "session_manager",
        "execution_probe",
        "cron",
        "inspection"
      ]
    },
    "RuntimeCronConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "interval"
      ]
    },
    "RuntimeDockerConfig": {
      "properties": {
        "command": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "run_args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cpus": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "memory_swap": {
          "type": "string"
        },
        "pids_limit": {
          "type": "string"
        },
        "network": {
          "type": "string"
        },
        "read_only_rootfs": {
          "type": "boolean"
        },
        "tmpfs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object",
      "required": [
        "command",
        "image",
        "run_args",
        "cpus",
        "memory",
        "memory_swap",
        "pids_limit",
        "network",
        "read_only_rootfs",
        "tmpfs"
      ]
    },
    "RuntimeDriverConfig": {
      "properties": {
        "id": {
          "type": "string",
          "description": "driver 唯一标识"
        },
        "launch_command": {
          "type": "string",
          "description": "启动命令"
        },
        "launch_args": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "启动参数"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "注入环境变量"
        },
        "capabilities_max": {
          "$ref": "#/$defs/CapabilitiesConfig",
          "description": "能力上限"
        }
      },
      "type": "object",
      "required": [
        "id",
        "launch_command",
        "launch_args",
        "env",
        "capabilities_max"
      ]
    },
    "RuntimeExecutionProbeConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "after": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "idle_after": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "timeout": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "max_attempts": {
          "type": "integer"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "interval",
        "after",
        "idle_after",
        "timeout",
        "max_attempts"
      ]
    },
    "RuntimeInspectionConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "lookback_hours": {
          "type": "integer"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "interval",
        "lookback_hours"
      ]
    },
    "RuntimeLLMConfig": {
      "properties": {
        "default_config_id": {
          "type": "string",
          "description": "当前默认启用的 LLM 配置 ID"
        },
        "configs": {
          "items": {
            "$ref": "#/$defs/RuntimeLLMEntryConfig"
          },
          "type": "array",
          "description": "可维护的多条 LLM 配置项"
        }
      },
      "type": "object",
      "required": [
        "default_config_id",
        "configs"
      ]
    },
    "RuntimeLLMEntryConfig": {
      "properties": {
        "id": {
          "type": "string",
          "description": "配置唯一标识"
        },
        "type": {
          "type": "string",
          "description": "LLM provider 类型（openai_chat_completion / openai_response / anthropic）"
        },
        "base_url": {
          "type": "string",
          "description": "LLM API 根地址"
        },
        "api_key": {
          "type": "string",
          "description": "LLM API 密钥"
        },
        "model": {
          "type": "string",
          "description": "默认模型名"
        }
      },
      "type": "object",
      "required": [
        "id",
        "type",
        "base_url",
        "api_key",
        "model"
      ]
    },
    "RuntimeLiteBoxConfig": {
      "properties": {
        "bridge_command": {
          "type": "string"
        },
        "bridge_args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "runner_path": {
          "type": "string"
        },
        "runner_args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object",
      "required": [
        "bridge_command",
        "bridge_args",
        "runner_path",
        "runner_args"
      ]
    },
    "RuntimeMCPConfig": {
      "properties": {
        "servers": {
          "items": {
            "$ref": "#/$defs/RuntimeMCPServerConfig"
          },
          "type": "array"
        },
        "profile_bindings": {
          "items": {
            "$ref": "#/$defs/RuntimeMCPProfileBindingConfig"
          },
          "type": "array"
        }
      },
      "type": "object",
      "required": [
        "servers",
        "profile_bindings"
      ]
    },
    "RuntimeMCPProfileBindingConfig": {
      "properties": {
        "profile": {
          "type": "string"
        },
        "server": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "tool_mode": {
          "type": "string"
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object",
      "required": [
        "profile",
        "server",
        "enabled",
        "tool_mode",
        "tools"
      ]
    },
    "RuntimeMCPServerConfig": {
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "transport": {
          "type": "string"
        },
        "endpoint": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        "auth_secret_ref": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "type": "object",
      "required": [
        "id",
        "name",
        "kind",
        "transport",
        "endpoint",
        "command",
        "args",
        "env",
        "auth_secret_ref",
        "enabled"
      ]
    },
    "RuntimeNATSConfig": {
      "properties": {
        "url": {
          "type": "string"
        },
        "embedded": {
          "type": "boolean"
        },
        "embedded_data_dir": {
          "type": "string"
        },
        "stream_prefix": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "url",
        "embedded",
        "embedded_data_dir",
        "stream_prefix"
      ]
    },
    "RuntimePRMergeStatePromptConfig": {
      "properties": {
        "default": {
          "type": "string"
        },
        "dirty": {
          "type": "string"
        },
        "blocked": {
          "type": "string"
        },
        "behind": {
          "type": "string"
        },
        "unstable": {
          "type": "string"
        },
        "draft": {
          "type": "string"
        }
      },
      "type": "object",
      "required": [
        "default",
        "dirty",
        "blocked",
        "behind",
        "unstable",
        "draft"
      ]
    },
    "RuntimePRPromptProvidersConfig": {
      "properties": {
        "github": {
          "$ref": "#/$defs/RuntimePRProviderPromptConfig"
        },
        "codeup": {
          "$ref": "#/$defs/RuntimePRProviderPromptConfig"
        },
        "gitlab": {
          "$ref": "#/$defs/RuntimePRProviderPromptConfig"
        }
      },
      "type": "object",
      "required": [
        "github",
        "codeup",
        "gitlab"
      ]
    },
    "RuntimePRProviderPromptConfig": {
      "properties": {
        "implement_objective": {
          "type": "string"
        },
        "gate_objective": {
          "type": "string"
        },
        "merge_rework_feedback": {
          "type": "string"
        },
        "merge_states": {
          "$ref": "#/$defs/RuntimePRMergeStatePromptConfig"
        }
      },
      "type": "object",
      "required": [
        "implement_objective",
        "gate_objective",
        "merge_rework_feedback",
        "merge_states"
      ]
    },
    "RuntimeProfileConfig": {
      "properties": {
        "id": {
          "type": "string",
          "description": "profile 唯一标识"
        },
        "name": {
          "type": "string",
          "description": "展示名称"
        },
        "driver": {
          "type": "string",
          "description": "引用的 driver ID"
        },
        "role": {
          "type": "string",
          "description": "运行时角色"
        },
        "capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "能力标签"
        },
        "actions_allowed": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "允许动作"
        },
        "prompt_template": {
          "type": "string",
          "description": "提示词模板名"
        },
        "skills": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "启用 skill 列表"
        },
        "session": {
          "$ref": "#/$defs/RuntimeSessionConfig",
          "description": "会话复用配置"
        },
        "mcp": {
          "$ref": "#/$defs/MCPConfig",
          "description": "MCP 配置"
        }
      },
      "type": "object",
      "required": [
        "id",
        "name",
        "driver",
        "role",
        "capabilities",
        "actions_allowed",
        "prompt_template",
        "skills",
        "session",
        "mcp"
      ]
    },
    "RuntimePromptsConfig": {
      "properties": {
        "rework_followup": {
          "type": "string"
        },
        "continue_followup": {
          "type": "string"
        },
        "pr_implement_objective": {
          "type": "string"
        },
        "pr_gate_objective": {
          "type": "string"
        },
        "pr_merge_rework_feedback": {
          "type": "string"
        },
        "pr_providers": {
          "$ref": "#/$defs/RuntimePRPromptProvidersConfig"
        }
      },
      "type": "object",
      "required": [
        "rework_followup",
        "continue_followup",
        "pr_implement_objective",
        "pr_gate_objective",
        "pr_merge_rework_feedback",
        "pr_providers"
      ]
    },
    "RuntimeSandboxConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string"
        },
        "litebox": {
          "$ref": "#/$defs/RuntimeLiteBoxConfig"
        },
        "docker": {
          "$ref": "#/$defs/RuntimeDockerConfig"
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "provider",
        "litebox",
        "docker"
      ]
    },
    "RuntimeSessionConfig": {
      "properties": {
        "reuse": {
          "type": "boolean",
          "description": "是否复用 session"
        },
        "max_turns": {
          "type": "integer",
          "description": "单 session 最大轮数"
        },
        "idle_ttl": {
          "type": "string",
          "description": "空闲过期时间",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "thread_boot_template": {
          "type": "string"
        },
        "max_context_tokens": {
          "type": "integer"
        },
        "context_warn_ratio": {
          "type": "number"
        }
      },
      "type": "object",
      "required": [
        "reuse",
        "max_turns",
        "idle_ttl",
        "thread_boot_template",
        "max_context_tokens",
        "context_warn_ratio"
      ]
    },
    "RuntimeSessionManagerConfig": {
      "properties": {
        "mode": {
          "type": "string"
        },
        "server_id": {
          "type": "string"
        },
        "nats": {
          "$ref": "#/$defs/RuntimeNATSConfig"
        }
      },
      "type": "object",
      "required": [
        "mode",
        "server_id",
        "nats"
      ]
    },
    "SchedulerConfig": {
      "properties": {
        "max_global_agents": {
          "type": "integer",
          "description": "全局最多同时运行的 agent 数"
        },
        "max_project_runs": {
          "type": "integer",
          "description": "每个项目最多的并发 run 数"
        },
        "watchdog": {
          "$ref": "#/$defs/WatchdogConfig"
        }
      },
      "type": "object",
      "required": [
        "max_global_agents",
        "max_project_runs",
        "watchdog"
      ]
    },
    "ServerConfig": {
      "properties": {
        "host": {
          "type": "string",
          "description": "监听地址（127.0.0.1 = 仅本地）"
        },
        "port": {
          "type": "integer",
          "description": "监听端口"
        },
        "auth_required": {
          "type": "boolean"
        }
      },
      "type": "object",
      "required": [
        "host",
        "port",
        "auth_required"
      ]
    },
    "StoreConfig": {
      "properties": {
        "driver": {
          "type": "string",
          "description": "存储驱动（sqlite）"
        },
        "path": {
          "type": "string",
          "description": "数据库文件路径（相对项目根目录）"
        }
      },
      "type": "object",
      "required": [
        "driver",
        "path"
      ]
    },
    "WatchdogConfig": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "stuck_run_ttl": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "stuck_merge_ttl": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        },
        "queue_stale_ttl": {
          "type": "string",
          "examples": [
            "2h",
            "30m",
            "10s",
            "500ms"
          ]
        }
      },
      "type": "object",
      "required": [
        "enabled",
        "interval",
        "stuck_run_ttl",
        "stuck_merge_ttl",
        "queue_stale_ttl"
      ]
    }
  },
  "title": "AI Workflow Config",
  "description": "ai-workflow 编排器配置 (.ai-workflow/config.toml)"
}
